# --- Server Configuration ---
PORT=5000
JWT_SECRET=mediscan_jwt_fallback_secret_key

# --- Database & Storage Configuration ---
MONGODB_URI=mongodb://127.0.0.1:27017/mediscan
UPLOADS_DIR=./uploads

# --- Clinical AI & LLM Configuration ---
# Optional: Add your Google Gemini API key to query live models
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Google OAuth Credentials ---
# Add your Google Developer Console OAuth credentials below to replace the simulator
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Forgot Password SMTP Email Server ---
# Add your SMTP email transport credentials below to send live reset links
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-smtp-app-password
EMAIL_FROM=MediScan AI <noreply@mediscan.ai>

# --- Frontend API Reference ---
# Used to link the React Vite client
VITE_API_URL=http://localhost:5000/api
